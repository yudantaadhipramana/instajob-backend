// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  fullName        String
  password        String?
  googleId        String?   @unique
  avatarUrl       String?
  emailVerified   Boolean   @default(false)
  subscriptionType String   @default("free") // free, pro, enterprise
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  // Relations - SECTION 1-2
  jobPreferences  JobPreferences?
  applications    Application[]
  savedJobs       SavedJob[]
  activityLogs    ActivityLog[]
  
  // Relations - SECTION 3A: Bot Ecosystem
  ownedBots       BotProfile[] @relation("BotOwner")
  ownedFleets     BotFleet[] @relation("FleetOwner")
  subscriptionTokens SubscriptionToken[] @relation("SubscriptionTokens")
  jobBatches      JobBatch[] @relation("JobBatches")
}

model JobPreferences {
  id              String    @id @default(cuid())
  userId          String    @unique
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Job search criteria
  jobTypes        String[]  // full-time, part-time, contract
  locations       String[]  // ["Jakarta", "Remote", etc]
  salaryMin       Int?
  salaryMax       Int?
  skills          String[]  // ["React", "TypeScript", etc]
  experienceLevel String?   // junior, mid, senior
  
  // Auto-apply settings
  autoApply       Boolean   @default(false)
  maxApplicationsPerDay Int @default(10)
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Application {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Job details
  jobId           String?
  jobTitle        String
  company         String
  companyLogo     String?
  jobUrl          String?
  jobDescription  String?
  salary          String?
  location        String?
  
  // Application status
  status          String    @default("applied") // applied, reviewed, interviewing, offered, rejected
  appliedAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  // Cover letter
  coverLetter     String?
  
  // Tracking
  notes           String?
  
  @@index([userId, status])
  @@index([userId, appliedAt])
}

model SavedJob {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  jobId           String
  jobTitle        String
  company         String
  companyLogo     String?
  jobUrl          String?
  salary          String?
  location        String?
  
  savedAt         DateTime  @default(now())
  
  @@unique([userId, jobId])
}

model ActivityLog {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  action          String    // login, apply, save_job, update_profile, etc
  details         Json?
  ipAddress       String?
  userAgent       String?
  
  createdAt       DateTime  @default(now())
  
  @@index([userId, createdAt])
}

// SECTION 3A: BOT ECOSYSTEM MODELS

model BotProfile {
  id              String    @id @default(cuid())
  botId           String    @unique // Telegram bot token or custom ID
  botName         String
  telegramBotToken String? // Optional: for Telegram bots
  botStatus       String    @default("ACTIVE") // ACTIVE, INACTIVE, SUSPENDED
  
  ownerUserId     String
  owner           User      @relation("BotOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  
  // Fleet relationship
  fleetId         String?
  fleet           BotFleet? @relation(fields: [fleetId], references: [id], onDelete: SetNull)
  
  // Bot activity tracking
  lastHeartbeat   DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  // Relations
  batches         JobBatch[]
  analytics       BotAnalytics[]
  
  @@index([ownerUserId])
  @@index([botStatus])
  @@index([fleetId])
}

model BotFleet {
  id              String    @id @default(cuid())
  fleetName       String
  description     String?
  
  ownerUserId     String
  owner           User      @relation("FleetOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  
  // Bot members
  bots            BotProfile[]
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@index([ownerUserId])
}

model SubscriptionToken {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation("SubscriptionTokens", fields: [userId], references: [id], onDelete: Cascade)
  
  tokenHash       String    @unique // SHA256 hash of actual token
  scopes          String[]  // ["job_discovery", "bot_control", "analytics"]
  
  expiresAt       DateTime
  isRevoked       Boolean   @default(false)
  
  createdAt       DateTime  @default(now())
  revokedAt       DateTime?
  
  @@index([userId])
  @@index([expiresAt])
  @@index([isRevoked])
}

model JobBatch {
  id              String    @id @default(cuid())
  
  botId           String
  bot             BotProfile @relation(fields: [botId], references: [id], onDelete: Cascade)
  
  userId          String
  user            User      @relation("JobBatches", fields: [userId], references: [id], onDelete: Cascade)
  
  // Job references
  jobIds          String[]  // Array of job IDs from Job model
  
  // Batch status
  status          String    @default("PENDING") // PENDING, PROCESSING, COMPLETED, FAILED
  
  // Timestamps
  createdAt       DateTime  @default(now())
  completedAt     DateTime?
  
  @@index([botId])
  @@index([userId])
  @@index([status])
}

model BotAnalytics {
  id              String    @id @default(cuid())
  
  botId           String
  bot             BotProfile @relation(fields: [botId], references: [id], onDelete: Cascade)
  
  // Analytics date (daily aggregation)
  date            DateTime  @default(now())
  
  // Metrics
  jobsDiscovered  Int       @default(0)
  jobsApplied     Int       @default(0)
  successRate     Float     @default(0) // 0-1 scale
  averageTimePerJob Int     @default(0) // milliseconds
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@index([botId])
  @@index([date])
}
