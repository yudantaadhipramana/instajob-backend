// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String   @id @default(cuid())
  email            String   @unique
  fullName         String
  password         String?
  googleId         String?  @unique
  avatarUrl        String?
  emailVerified    Boolean  @default(false)
  subscriptionType String   @default("free") // free, pro, enterprise
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  jobPreferences JobPreferences?
  applications   Application[]
  savedJobs      SavedJob[]
  activityLogs   ActivityLog[]
}

model JobPreferences {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Job search criteria
  jobTypes        String[] // full-time, part-time, contract
  locations       String[] // ["Jakarta", "Remote", etc]
  salaryMin       Int?
  salaryMax       Int?
  skills          String[] // ["React", "TypeScript", etc]
  experienceLevel String? // junior, mid, senior

  // Auto-apply settings
  autoApply             Boolean @default(false)
  maxApplicationsPerDay Int     @default(10)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Application {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Job details
  jobId          String?
  jobTitle       String
  company        String
  companyLogo    String?
  jobUrl         String?
  jobDescription String?
  salary         String?
  location       String?

  // Application status
  status    String   @default("applied") // applied, reviewed, interviewing, offered, rejected
  appliedAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Cover letter
  coverLetter String?

  // Tracking
  notes String?

  @@index([userId, status])
  @@index([userId, appliedAt])
}

model SavedJob {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  jobId       String
  jobTitle    String
  company     String
  companyLogo String?
  jobUrl      String?
  salary      String?
  location    String?

  savedAt DateTime @default(now())

  @@unique([userId, jobId])
}

model ActivityLog {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  action    String // login, apply, save_job, update_profile, etc
  details   Json?
  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}
